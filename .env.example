# ============================================
# BANDHAN BACKEND — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to GitHub!
# ============================================

# Server
PORT=3000
NODE_ENV=production

# JWT Secret (change this to any random long string)
JWT_SECRET=bandhan_change_this_to_something_random_and_long_2025

# MongoDB (get from MongoDB Atlas)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bandhan

# Razorpay (get from razorpay.com dashboard)
# RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx
# RAZORPAY_KEY_SECRET=your_secret_here

# ImgBB (free photo hosting - get key from imgbb.com/api)
# IMGBB_API_KEY=your_imgbb_key_here

# Email (optional - for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password

# Frontend URL (for CORS)
FRONTEND_URL=https://your-app.vercel.app
